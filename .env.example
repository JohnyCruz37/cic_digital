# localhost no host; o serviço api no Docker Compose sobrescreve para postgres
POSTGRES_HOST=localhost
POSTGRES_USER=cic
POSTGRES_PASSWORD=cic
POSTGRES_DB=cic_digital
POSTGRES_PORT=5432

# Conexão read-only — padrão da API (rotas de leitura e /ready)
POSTGRES_READ_USER=cic_read
POSTGRES_READ_PASSWORD=cic_read

API_PORT=8000

APP_ENV=development
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Opcional: sobrescreve montagem automática em core/config.py
# Admin — Alembic, seeds e manutenção (POSTGRES_USER/PASSWORD acima)
# DATABASE_URL=postgresql+psycopg2://cic:cic@postgres:5432/cic_digital
# Read-only — conexão padrão da API
# DATABASE_READ_URL=postgresql+psycopg2://cic_read:cic_read@postgres:5432/cic_digital

# Fora do Docker (Alembic/psql no host): POSTGRES_HOST=localhost (padrão acima)
# Dentro do Docker (docker compose exec api …): POSTGRES_HOST=postgres (já definido no compose)
